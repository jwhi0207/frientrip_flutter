rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // User profile images — owner can read/write, anyone authenticated can read
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Trip assets (thumbnails, lodging images) — authenticated users can read,
    // only the uploader (any authenticated user) can write
    match /trips/{tripId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

  }
}
